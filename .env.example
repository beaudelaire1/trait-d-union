# ==============================================================================
# Trait d'Union Studio - Variables d'environnement
# ==============================================================================
# Copiez ce fichier en .env et renseignez vos valeurs
# NE JAMAIS COMMITER LE FICHIER .env

# ==============================================================================
# DJANGO
# ==============================================================================
DJANGO_SECRET_KEY=
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Must be at least 32 characters
DJANGO_SETTINGS_MODULE=config.settings.development
# En production: config.settings.production

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# En production: traitdunion.it,www.traitdunion.it,.onrender.com

CSRF_TRUSTED_ORIGINS=http://localhost:8000
# En production: https://traitdunion.it,https://www.traitdunion.it

SITE_URL=http://localhost:8000
# En production: https://traitdunion.it

# ==============================================================================
# BASE DE DONNÉES
# ==============================================================================
# Render fournit automatiquement DATABASE_URL
# Pour le dev local, on utilise SQLite par défaut

# PostgreSQL (production Render)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# MySQL (si besoin)
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=nom_base
# DB_USER=utilisateur
# DB_PASSWORD=mot_de_passe
# DB_HOST=localhost
# DB_PORT=3306

# ==============================================================================
# BREVO (ex-Sendinblue) - EMAILS TRANSACTIONNELS
# ==============================================================================
# Clé API Brevo - Obtenez-la sur https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-votre-cle-api-ici

# Configuration expéditeur
DEFAULT_FROM_EMAIL=contact@traitdunion.it
DEFAULT_FROM_NAME=Trait d'Union Studio

# Email admin pour les notifications internes
ADMIN_EMAIL=admin@traitdunion.it

# Email pour les notifications de tâches (leads, alertes)
TASK_NOTIFICATION_EMAIL=info@traitdunion.it

# ==============================================================================
# SMTP FALLBACK (optionnel - non recommandé sur Render)
# ==============================================================================
# Utilisé uniquement si Brevo n'est pas configuré
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=votre-email@exemple.com
# EMAIL_HOST_PASSWORD=votre-mot-de-passe-smtp

# ==============================================================================
# STOCKAGE S3 / CLOUDFLARE R2 (médias en production)
# ==============================================================================
# Cloudflare R2 est recommandé (moins cher, compatible S3)
# AWS_ACCESS_KEY_ID=votre-access-key
# AWS_SECRET_ACCESS_KEY=votre-secret-key
# AWS_STORAGE_BUCKET_NAME=tus-media
# AWS_S3_ENDPOINT_URL=https://xxxxx.r2.cloudflarestorage.com
# AWS_S3_REGION_NAME=auto
# AWS_S3_CUSTOM_DOMAIN=cdn.traitdunion.it

# ==============================================================================
# REDIS (cache et sessions - optionnel)
# ==============================================================================
# Render fournit automatiquement REDIS_URL si vous ajoutez Redis
# REDIS_URL=redis://user:password@host:6379

# ==============================================================================
# RECAPTCHA v2 (checkbox)
# ==============================================================================
# Obtenez vos clés sur https://www.google.com/recaptcha/admin
# Choisissez reCAPTCHA v2 "Je ne suis pas un robot" (checkbox)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ==============================================================================
# CLOUDFLARE TURNSTILE (CAPTCHA alternatif)
# ==============================================================================
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ==============================================================================
# FACTURATION / BRANDING
# ==============================================================================
# IBAN et BIC pour les factures et devis (ne jamais commiter en clair)
INVOICE_IBAN=FR76 XXXX XXXX XXXX XXXX XXXX XXX
INVOICE_BIC=XXXXXXXX

# ==============================================================================
# PAIEMENT STRIPE
# ==============================================================================
# Dashboard: https://dashboard.stripe.com/apikeys
# Mode TEST
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Mode LIVE (décommenter en production)
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# ==============================================================================
# GOOGLE ANALYTICS 4 (tracking & SEO)
# ==============================================================================
# Créez une propriété GA4 sur https://analytics.google.com
# Format: G-XXXXXXXXXX
GA4_MEASUREMENT_ID=

# ==============================================================================
# SENTRY (monitoring erreurs - production)
# ==============================================================================
# Créez un projet sur https://sentry.io
SENTRY_DSN=

# ==============================================================================
# CLOUDINARY (médias en production - alternative à S3)
# ==============================================================================
# Gratuit jusqu'à 25 crédits/mois - https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==============================================================================
# SUPERUSER (création automatique sur Render)
# ==============================================================================
DJANGO_SUPERUSER_USERNAME=admin_tus
DJANGO_SUPERUSER_EMAIL=admin@traitdunion.it
DJANGO_SUPERUSER_PASSWORD=DefinissezUnMotDePasse_Complexe123!

# ==============================================================================
# FACTURATION ÉLECTRONIQUE — Plateforme Agréée DGFiP (réforme FR 2026/2027)
# ==============================================================================
# Voir .kiro/steering/einvoicing-fr.md pour le cadre réglementaire complet.
# Provider supportés (adapter swappable côté apps/einvoicing/pdp/) :
#   - iopole      → https://iopole.fr (par défaut)
#   - b2brouter   → https://www.b2brouter.net
EINVOICING_PDP_PROVIDER=iopole

# 1 = sandbox (préprod), 0 = production
EINVOICING_PDP_SANDBOX=1

# Base URL — laissez vide pour utiliser celle par défaut de l'adapter
# IOPOLE prod    : https://api.iopole.fr
# IOPOLE sandbox : https://sandbox.iopole.fr
EINVOICING_PDP_BASE_URL=

# ─── IOPOLE (OAuth2 client_credentials) ──────────────────────────────────────
# Identifiants techniques fournis par IOPOLE à l'inscription développeur.
EINVOICING_PDP_OAUTH_CLIENT_ID=
EINVOICING_PDP_OAUTH_CLIENT_SECRET=

# Override des chemins API si IOPOLE en notifie une évolution
EINVOICING_PDP_TOKEN_PATH=/oauth/token
EINVOICING_PDP_API_PREFIX=/v1

# ─── B2BRouter (X-B2B-API-Key) — utilisé uniquement si PROVIDER=b2brouter ────
EINVOICING_PDP_API_KEY=
EINVOICING_PDP_ACCOUNT_ID=
EINVOICING_PDP_API_VERSION=2026-03-02

# ─── Commun à tous les providers ─────────────────────────────────────────────
EINVOICING_PDP_TIMEOUT=20
EINVOICING_PDP_RETRIES=5

# Secret HMAC partagé pour vérifier la signature des webhooks entrants
# (à configurer côté PA dans son back-office "Developers > Webhooks")
EINVOICING_PDP_WEBHOOK_SECRET=

# Régime fiscal de l'émetteur :
#   STANDARD             → assujetti normal (TVA collectée)
#   FRANCHISE            → franchise en base art. 293 B CGI (métropole)
#   DOM_GUYANE_MAYOTTE   → TVA non applicable art. 294 CGI (Guyane / Mayotte)
#   EXEMPT_OTHER         → autre exonération
EINVOICING_VAT_REGIME=DOM_GUYANE_MAYOTTE

# Format de sortie : FACTURX (recommandé), UBL ou CII
EINVOICING_FORMAT=FACTURX

# Profil Factur-X : MINIMUM, BASIC_WL, BASIC, EN16931 (recommandé), EXTENDED
EINVOICING_FACTURX_PROFILE=EN16931

# Identité émetteur (renseignée si différente du INVOICE_BRANDING)
EINVOICING_SIREN=
EINVOICING_LEGAL_FORM=AE
EINVOICING_COUNTRY=FR
EINVOICING_PEPPOL_ID=

# E-reporting B2C / cross-border (transactions Stripe agrégées vers la PA)
EINVOICING_E_REPORTING=1


# ==============================================================================
# AVIS GOOGLE BUSINESS — synchronisation automatique (Places API New)
# ==============================================================================
# Création de la clé API : https://console.cloud.google.com/apis/credentials
# Activer l'API "Places API (New)" dans le projet Google Cloud.
# Récupérer le place_id : https://developers.google.com/maps/documentation/places/web-service/place-id
#
# La synchro alimente la table Testimonial (source='google').
# Cron recommandé en prod : toutes les 6 h (limite Google : 5 avis max par place).
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_REVIEWS_LANGUAGE=fr
